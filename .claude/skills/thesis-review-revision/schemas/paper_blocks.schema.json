{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PaperBlocks",
  "type": "object",
  "required": ["blocks"],
  "properties": {
    "source_file": { "type": "string" },
    "file_type": { "type": "string" },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["block_id", "type", "text", "page", "bbox", "section_id", "section_path", "order"],
        "properties": {
          "block_id": { "type": "string" },
          "type": { "type": "string", "enum": ["heading", "paragraph", "formula", "figure", "figure_caption", "table", "table_caption", "reference_item", "footnote", "endnote", "comment", "list_item", "unknown"] },
          "text": { "type": "string" },
          "page": { "type": ["integer", "null"], "minimum": 1 },
          "bbox": {
            "type": ["array", "null"],
            "items": { "type": "number" },
            "minItems": 4,
            "maxItems": 4
          },
          "section_id": { "type": ["string", "null"] },
          "section_path": { "type": "array", "items": { "type": "string" } },
          "order": { "type": "integer", "minimum": 0 },
          "style_name": { "type": ["string", "null"] },
          "style_id": { "type": ["string", "null"] },
          "docx_locator": {
            "type": "object",
            "required": ["body_index", "xml_tag"],
            "properties": {
              "body_index": { "type": "integer", "minimum": 1 },
              "xml_tag": { "type": "string" },
              "xpath_hint": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          },
          "assets": { "type": "array", "items": { "type": "string" } },
          "image_rids": { "type": "array", "items": { "type": "string" } },
          "table": {
            "type": "object",
            "properties": {
              "rows": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
