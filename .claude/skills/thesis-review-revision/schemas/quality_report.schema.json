{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QualityReport",
  "type": "object",
  "required": ["passed", "summary", "issues"],
  "properties": {
    "passed": { "type": "boolean" },
    "summary": {
      "type": "object",
      "required": ["total_comments", "passed_comments", "blocker_count", "warning_count"],
      "properties": {
        "total_comments": { "type": "integer", "minimum": 0 },
        "passed_comments": { "type": "integer", "minimum": 0 },
        "blocker_count": { "type": "integer", "minimum": 0 },
        "warning_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["comment_id", "severity", "problem_type", "problem", "fix"],
        "properties": {
          "comment_id": { "type": "string" },
          "severity": { "type": "string", "enum": ["blocker", "warning", "note"] },
          "problem_type": { "type": "string", "enum": ["hallucinated_data", "hallucinated_reference", "unsupported_claim", "missing_location", "missing_evidence", "overclaim_completed_revision", "vague_action", "missing_author_input_flag", "tone_problem", "schema_problem", "other"] },
          "problem": { "type": "string" },
          "fix": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

